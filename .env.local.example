PORT=8301
BROWSER=none
# Subdomain of your tunnel URL for stable restarts
# e.g. if your tunnel is https://abc123.apps-tunnel.monday.app, set TUNNEL_SUBDOMAIN=abc123
TUNNEL_SUBDOMAIN=

# Server
SERVER_PORT=3001
SKIP_AUTH=true
# From monday.com App Settings → Basic Information → Client Secret
MONDAY_CLIENT_SECRET=

# Client — your tunnel URL so the React app can reach the local backend
VITE_SERVER_BASE_URL=https://<your-tunnel-subdomain>.apps-tunnel.monday.app
