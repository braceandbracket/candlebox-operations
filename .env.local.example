PORT=8301
BROWSER=none
# Subdomain of your tunnel URL for stable restarts
# e.g. if your tunnel is https://abc123.apps-tunnel.monday.app, set TUNNEL_SUBDOMAIN=abc123
TUNNEL_SUBDOMAIN=

# Server
SERVER_PORT=3001
# Optional local-only bypass for API tests outside monday iframe.
# This is ignored in production and should stay false for normal tunnel development.
SKIP_AUTH=false
MONDAY_SIGNING_SECRET=
MONDAY_COL_SCENT_PROFILES=dropdown

# monday GraphQL — required for /webhooks/production-tasks when monday sends no auth header (normal for board automations).
# Create at: monday avatar → Developers → API token (or Admin → API)
MONDAY_API_TOKEN=

# Client — your tunnel URL so the React app can reach the local backend
VITE_SERVER_BASE_URL=https://<your-tunnel-subdomain>.apps-tunnel.monday.app

# Optional — Production Orders column ids (see docs/ops-setup.md). Uncomment to override defaults.
# VITE_MONDAY_COL_CLIENT_FIRST_NAME=text
# VITE_MONDAY_COL_CLIENT_LAST_NAME=text6
# VITE_MONDAY_COL_COMPANY=text_mm2h5g3q
# VITE_MONDAY_COL_EMAIL=email
# VITE_MONDAY_COL_PHONE=phone
# VITE_MONDAY_COL_ADDRESS=location
# VITE_MONDAY_COL_ORDER_RECEIVED=date_1
# VITE_MONDAY_COL_SCENT_PROFILES=dropdown
# VITE_MONDAY_COL_QUANTITY=numbers
# VITE_MONDAY_COL_INSCRIPTION=text5
