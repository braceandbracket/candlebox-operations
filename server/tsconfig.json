{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "composite": true
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
